###############################################################################
# NexusAI - PHP Library .gitignore
###############################################################################

# ─── Composer ────────────────────────────────────────────────────────────────
/vendor/
composer.phar

# Keep composer.lock ONLY if this were an application.
# For a LIBRARY, composer.lock should NOT be committed.
composer.lock

# ─── PHPUnit ─────────────────────────────────────────────────────────────────
.phpunit.cache/
.phpunit.result.cache
/build/
/coverage/
/.phpunit.cache

# ─── PHP CS Fixer ────────────────────────────────────────────────────────────
.php-cs-fixer.cache
.php_cs.cache

# ─── PHPStan ─────────────────────────────────────────────────────────────────
.phpstan-cache/
phpstan-result.neon

# ─── Environment & Secrets ───────────────────────────────────────────────────
.env
.env.*
!.env.example
*.key
*.pem
*.p12
*.pfx
secrets.php
secrets/

# ─── IDE & Editors ───────────────────────────────────────────────────────────
# JetBrains (PhpStorm, IntelliJ, etc.)
.idea/
*.iml
*.iws
*.ipr

# VS Code
.vscode/
*.code-workspace

# Sublime Text
*.sublime-project
*.sublime-workspace

# Vim / Neovim
*.swp
*.swo
*~
.netrwhist

# Emacs
*#
.#*

# Eclipse
.project
.classpath
.settings/

# ─── OS Generated ────────────────────────────────────────────────────────────
# macOS
.DS_Store
.DS_Store?
._*
.Spotlight-V100
.Trashes

# Windows
Thumbs.db
Thumbs.db:encryptable
ehthumbs.db
ehthumbs_vista.db
Desktop.ini
$RECYCLE.BIN/
*.lnk

# Linux
*~

# ─── Logs & Temp Files ───────────────────────────────────────────────────────
*.log
logs/
tmp/
temp/
/storage/logs/

# ─── Build Artifacts ─────────────────────────────────────────────────────────
/dist/
/build/
/output/
*.phar

# ─── Node (if any tooling uses it) ───────────────────────────────────────────
node_modules/
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnp.*

# ─── Docker (local dev overrides) ────────────────────────────────────────────
docker-compose.override.yml

# ─── Misc ────────────────────────────────────────────────────────────────────
*.bak
*.orig
*.patch
.cache/
